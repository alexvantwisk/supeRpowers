#!/usr/bin/env bash
# SessionStart hook for supeRpowers plugin
# Detects R project type and surfaces relevant skills and agents.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Detection flags ---
is_r_package=false
is_shiny=false
is_quarto=false
is_targets=false
is_clinical=false
is_bayesian=false
is_r_project=false

# R Package: DESCRIPTION + (R/ or NAMESPACE)
if [ -f "DESCRIPTION" ] && { [ -d "R" ] || [ -f "NAMESPACE" ]; }; then
  is_r_package=true
fi

# Shiny App: app.R, ui.R+server.R, golem, or rhino
if [ -f "app.R" ] || { [ -f "ui.R" ] && [ -f "server.R" ]; }; then
  is_shiny=true
fi
if [ "$is_r_package" = true ] && [ -f "inst/golem-config.yml" ]; then
  is_shiny=true
fi
if [ -f "rhino.yml" ]; then
  is_shiny=true
fi

# Quarto project
if [ -f "_quarto.yml" ]; then
  is_quarto=true
fi

# Word report pipeline: any *.qmd with format: docx, OR a reference.docx file
is_word_report=false
if find . -maxdepth 4 -type f -name '*.qmd' -print0 2>/dev/null | xargs -0 grep -lE '^\s*(format:\s*docx|docx:|reference-doc:)' 2>/dev/null | head -n 1 | grep -q .; then
  is_word_report=true
fi
if [ -f "reference.docx" ] || [ -f "inst/templates/reference.docx" ] || [ -f "report/reference.docx" ]; then
  is_word_report=true
fi

# Targets pipeline
if [ -f "_targets.R" ]; then
  is_targets=true
fi

# Clinical/Pharma: admiral/pharmaverse in DESCRIPTION, or adam/sdtm dirs
if [ "$is_r_package" = true ] && [ -f "DESCRIPTION" ]; then
  if grep -qiE 'admiral|pharmaverse|sdtm\.oak|sdtm\b|adam' "DESCRIPTION" 2>/dev/null; then
    is_clinical=true
  fi
fi
if [ -d "adam" ] || [ -d "sdtm" ] || [ -d "ADAM" ] || [ -d "SDTM" ]; then
  is_clinical=true
fi

# Bayesian: brms/rstanarm/cmdstanr/posterior in DESCRIPTION, .stan files, or _brms_*.rds artifacts
if [ "$is_r_package" = true ] && [ -f "DESCRIPTION" ]; then
  if grep -qiE 'brms|rstanarm|cmdstanr|^posterior$|tidybayes' "DESCRIPTION" 2>/dev/null; then
    is_bayesian=true
  fi
fi
if find . -maxdepth 4 -type f -name '*.stan' -print -quit 2>/dev/null | grep -q .; then
  is_bayesian=true
fi
if find . -maxdepth 4 -type f -name '_brms_*.rds' -print -quit 2>/dev/null | grep -q .; then
  is_bayesian=true
fi

# General R project: .Rproj, .R files, or R/ dir (but not already a package)
if compgen -G "*.Rproj" >/dev/null 2>&1 || compgen -G "*.R" >/dev/null 2>&1 || [ -d "R" ]; then
  is_r_project=true
fi

# --- Build context ---
skills=""
if [ "$is_r_package" = true ]; then
  skills="${skills}R package detected. Key skills: /r-package-dev, /r-tdd, /r-pkg-release, /r-tdd-cycle. Agents: r-pkg-check, r-code-reviewer, r-dependency-manager.\\n"
fi
if [ "$is_shiny" = true ]; then
  skills="${skills}Shiny app detected. Key skills: /r-shiny, /r-shiny-app. Agent: r-shiny-architect.\\n"
fi
if [ "$is_quarto" = true ]; then
  skills="${skills}Quarto project detected. Key skill: /r-quarto.\\n"
fi
if [ "$is_word_report" = true ]; then
  skills="${skills}Word .docx report pipeline detected. Key skills: /r-reporting, /r-report.\\n"
fi
if [ "$is_targets" = true ]; then
  skills="${skills}Targets pipeline detected. Key skill: /r-targets.\\n"
fi
if [ "$is_clinical" = true ]; then
  skills="${skills}Clinical/pharma project detected. Key skill: /r-clinical. Agent: r-statistician.\\n"
fi
if [ "$is_bayesian" = true ]; then
  skills="${skills}Bayesian / Stan project detected. Key skill: /r-bayesian. Agent: r-statistician.\\n"
fi
if [ "$is_r_project" = true ] && [ "$is_r_package" = false ]; then
  skills="${skills}R project detected. Key skills: /r-data-analysis, /r-visualization, /r-stats, /r-analysis. Agent: r-statistician.\\n"
fi

# Nothing detected — exit silently
if [ -z "$skills" ]; then
  echo '{}'
  exit 0
fi

# --- R session info (only reached when a project was detected) ---
# Pick a timeout command (mirror post-tool-use-format).
r_probe_timeout=""
if command -v timeout >/dev/null 2>&1; then
  r_probe_timeout="timeout 5"
elif command -v gtimeout >/dev/null 2>&1; then
  r_probe_timeout="gtimeout 5"
fi

r_session_info=""
if command -v Rscript >/dev/null 2>&1; then
  r_version=$($r_probe_timeout Rscript --vanilla -e 'cat(R.version$major, R.version$minor, sep=".")' 2>/dev/null || true)
  if [ -n "$r_version" ]; then
    r_platform=$($r_probe_timeout Rscript --vanilla -e 'cat(R.version$platform)' 2>/dev/null || true)
    r_session_info="R ${r_version} detected. Platform: ${r_platform:-unknown}."
    r_pkg_versions=$($r_probe_timeout Rscript --vanilla -e '
      pkgs <- c("dplyr", "ggplot2", "tidyr", "purrr", "readr", "stringr",
                "forcats", "lubridate", "shiny", "testthat", "gt", "targets")
      installed <- pkgs[pkgs %in% rownames(installed.packages())]
      if (length(installed) > 0) {
        versions <- vapply(installed, \(p) as.character(packageVersion(p)), character(1))
        cat(paste(installed, versions, sep = " "), sep = ", ")
      }
    ' 2>/dev/null || true)
    if [ -n "$r_pkg_versions" ]; then
      r_session_info="${r_session_info}\\n  Key packages: ${r_pkg_versions}"
    fi
  fi
fi
if [ -f "renv.lock" ]; then
  r_session_info="${r_session_info}\\n  renv.lock found — package versions locked."
fi

# --- Escape for JSON ---
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

r_info=""
if [ -n "$r_session_info" ]; then
  r_info="${r_session_info}\\n"
fi

# --- MCP availability tip ---
# Call detect-mcp.sh once and branch on mcp_repl / r-btw registration so
# the tip reflects what the user actually has set up.
mcp_tip="Tip: run /r-mcp-setup to enable persistent R sessions (mcp-repl) or live IDE awareness (btw/mcptools)."
if [ -x "${SCRIPT_DIR}/detect-mcp.sh" ]; then
  mcp_json=$("${SCRIPT_DIR}/detect-mcp.sh" 2>/dev/null || echo '{}')
  has_repl=false
  has_btw=false
  if echo "$mcp_json" | grep -q '"mcp_repl_registered":true'; then
    has_repl=true
  fi
  if echo "$mcp_json" | grep -q '"mcp_registered":true'; then
    has_btw=true
  fi
  if [ "$has_repl" = true ] && [ "$has_btw" = true ]; then
    mcp_tip="Tip: mcp-repl (persistent agent R session) + btw/mcptools (live IDE awareness) both active — use repl for stateful execution, btw_tool_* for IDE-bridged introspection."
  elif [ "$has_repl" = true ]; then
    mcp_tip="Tip: mcp-repl active — use repl for stateful R execution across calls, repl_reset for a clean slate."
  elif [ "$has_btw" = true ]; then
    mcp_tip="Tip: btw/mcptools MCP enhances all skills with live R session awareness."
  fi
fi

context="supeRpowers R plugin active.\\n${r_info}${skills}Use /r-* workflow skills for guided procedures, or describe your task to auto-route a knowledge skill.\\nNew here? Run /r-overview for the full inventory.\\n${mcp_tip}"
escaped_context=$(escape_for_json "$context")

# Platform-aware JSON output
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped_context"
fi

exit 0
