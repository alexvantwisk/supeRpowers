#!/usr/bin/env bash
# supeRpowers session-start hook
# Detects R project type and prints context about relevant skills and agents.
# Fires on: startup, resume, clear, compact.

set -euo pipefail

project_type="script"
skills_hint=""
agents_hint=""

# Detect R package (has DESCRIPTION with Package: field)
if [ -f "DESCRIPTION" ] && grep -q "^Package:" DESCRIPTION 2>/dev/null; then
  project_type="package"
  skills_hint="r-package-dev, r-tdd, r-debugging"
  agents_hint="r-pkg-check, r-code-reviewer, r-dependency-manager"
fi

# Detect RStudio project
if ls ./*.Rproj 1>/dev/null 2>&1; then
  if [ "$project_type" = "script" ]; then
    project_type="project"
    skills_hint="r-data-analysis, r-visualization, r-stats"
    agents_hint="r-statistician, r-code-reviewer"
  fi
fi

# Detect targets pipeline
if [ -f "_targets.R" ]; then
  project_type="targets-pipeline"
  skills_hint="r-targets, r-data-analysis, r-performance"
  agents_hint="r-code-reviewer, r-dependency-manager"
fi

# Detect Shiny app
if [ -f "app.R" ] || [ -f "server.R" ] || [ -f "ui.R" ]; then
  project_type="shiny-app"
  skills_hint="r-shiny, r-visualization, r-debugging"
  agents_hint="r-shiny-architect, r-code-reviewer"
fi

# Detect Quarto project
if [ -f "_quarto.yml" ] || ls ./*.qmd 1>/dev/null 2>&1; then
  if [ "$project_type" = "script" ]; then
    project_type="quarto"
    skills_hint="r-quarto, r-visualization, r-tables"
    agents_hint="r-code-reviewer"
  fi
fi

# Detect clinical project markers
if [ -f "DESCRIPTION" ] && grep -qE "pharmaverse|admiral|sdtm|adam" DESCRIPTION 2>/dev/null; then
  project_type="clinical"
  skills_hint="r-clinical, r-tables, r-stats"
  agents_hint="r-statistician, r-code-reviewer"
fi

# ---------------------------------------------------------------------------
# Extraction phase: gather compact project metadata
# Budget: ~12 lines worst-case. Each feature degrades gracefully.
# ---------------------------------------------------------------------------

desc_summary=""
desc_r_dep=""
desc_imports=""
ns_exports=""
renv_r_version=""
test_inventory=""
renv_packages=""

# 1. DESCRIPTION summary (package projects)
if [ -f "DESCRIPTION" ] && grep -q "^Package:" DESCRIPTION 2>/dev/null; then
  pkg_name=$(grep "^Package:" DESCRIPTION 2>/dev/null | sed 's/^Package: *//')
  pkg_version=$(grep "^Version:" DESCRIPTION 2>/dev/null | sed 's/^Version: *//')
  pkg_title=$(grep "^Title:" DESCRIPTION 2>/dev/null | sed 's/^Title: *//')
  if [ -n "$pkg_name" ]; then
    desc_summary="${pkg_name} ${pkg_version} — \"${pkg_title}\""
  fi

  # R version dependency from Depends field
  r_dep=$(sed -n '/^Depends:/,/^[^ ]/p' DESCRIPTION 2>/dev/null | sed '$d' | tr '\n' ' ' | grep -oE 'R \([^)]+\)' 2>/dev/null)
  if [ -n "$r_dep" ]; then
    desc_r_dep=$(echo "$r_dep" | sed 's/R (\(.*\))/\1/')
  fi

  # Imports list (handles continuation lines)
  raw_imports=$(sed -n '/^Imports:/,/^[^ ]/p' DESCRIPTION 2>/dev/null | sed '$d' | sed 's/^Imports://' | tr -d ' \n' | tr ',' '\n' | sed '/^$/d' | sort)
  if [ -n "$raw_imports" ]; then
    import_count=$(echo "$raw_imports" | wc -l | tr -d ' ')
    if [ "$import_count" -gt 15 ]; then
      overflow=$((import_count - 15))
      desc_imports="$(echo "$raw_imports" | head -15 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g'), ... (+${overflow} more)"
    else
      desc_imports=$(echo "$raw_imports" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
    fi
  fi
fi

# 2. NAMESPACE exports (package projects)
if [ -f "NAMESPACE" ]; then
  raw_exports=$(grep "^export(" NAMESPACE 2>/dev/null | sed 's/export(//;s/)//' | sort)
  export_pattern=$(grep "^exportPattern(" NAMESPACE 2>/dev/null | sed 's/exportPattern(//;s/)//' | head -1)
  if [ -n "$raw_exports" ]; then
    export_count=$(echo "$raw_exports" | wc -l | tr -d ' ')
    if [ "$export_count" -gt 20 ]; then
      overflow=$((export_count - 20))
      ns_exports="$(echo "$raw_exports" | head -20 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g'), ... (+${overflow} more)"
    else
      ns_exports=$(echo "$raw_exports" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
    fi
  elif [ -n "$export_pattern" ]; then
    ns_exports="pattern: ${export_pattern}"
  fi
fi

# 3. renv R version
if [ -f "renv.lock" ]; then
  renv_r_version=$(grep -A1 '"R"' renv.lock 2>/dev/null | grep -o '"Version": *"[^"]*"' | sed 's/"Version": *"//;s/"//')
fi

# 4. Test file inventory (package projects)
if [ -d "tests/testthat" ]; then
  raw_tests=$(ls tests/testthat/ 2>/dev/null | grep "^test-" | sed 's/\.R$//')
  if [ -n "$raw_tests" ]; then
    test_count=$(echo "$raw_tests" | wc -l | tr -d ' ')
    if [ "$test_count" -gt 10 ]; then
      overflow=$((test_count - 10))
      test_inventory="$(echo "$raw_tests" | head -10 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g'), ... (+${overflow} more)"
    else
      test_inventory=$(echo "$raw_tests" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
    fi
  fi
fi

# 5. renv package summary (non-package projects only)
if [ -f "renv.lock" ] && [ "$project_type" != "package" ] && [ "$project_type" != "clinical" ]; then
  raw_pkgs=$(grep -o '"Package": *"[^"]*"' renv.lock 2>/dev/null | sed 's/"Package": *"//;s/"//' | sort)
  if [ -n "$raw_pkgs" ]; then
    pkg_count=$(echo "$raw_pkgs" | wc -l | tr -d ' ')
    if [ "$pkg_count" -gt 15 ]; then
      overflow=$((pkg_count - 15))
      renv_packages="$(echo "$raw_pkgs" | head -15 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g'), ... (+${overflow} more)"
    else
      renv_packages=$(echo "$raw_pkgs" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Output phase
# ---------------------------------------------------------------------------

echo "R project detected: ${project_type}"
if [ -n "$skills_hint" ]; then
  echo "Recommended skills: ${skills_hint}"
fi
if [ -n "$agents_hint" ]; then
  echo "Recommended agents: ${agents_hint}"
fi
if [ -n "$desc_summary" ]; then
  echo "Package: ${desc_summary}"
fi
if [ -n "$desc_r_dep" ]; then
  echo "R dependency: ${desc_r_dep}"
fi
if [ -n "$desc_imports" ]; then
  echo "Imports: ${desc_imports}"
fi
if [ -n "$ns_exports" ]; then
  echo "Exports: ${ns_exports}"
fi
if [ -n "$renv_r_version" ]; then
  echo "renv R version: ${renv_r_version}"
fi
if [ -n "$test_inventory" ]; then
  echo "Tests: ${test_inventory}"
fi
if [ -n "$renv_packages" ]; then
  echo "renv packages: ${renv_packages}"
fi
